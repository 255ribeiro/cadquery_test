{
    "name": "CadQuery para Arquitetos",
    "build": {
        "dockerfile": "Dockerfile"
    },

    "postCreateCommand": "cd /workspaces/${localWorkspaceFolderBasename} && pixi install",

    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-toolsai.jupyter",
                "bernhard-42.ocp-cad-viewer"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/workspaces/${localWorkspaceFolderBasename}/.pixi/envs/default/bin/python",
                "jupyter.kernelSpecFindPreferredKernel": true
            }
        }
    },

    "forwardPorts": [3939],
    "portsAttributes": {
        "3939": {
            "label": "OCP CAD Viewer",
            "onAutoForward": "silent"
        }
    }
}