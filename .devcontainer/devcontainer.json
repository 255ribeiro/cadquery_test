{
    "name": "CadQuery para Arquitetos",
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    "mounts": [
        "source=${localWorkspaceFolderBasename}-pixi,target=${containerWorkspaceFolder}/.pixi,type=volume"
    ],
    "postCreateCommand": "sudo chown vscode .pixi && pixi install && pixi run python -m ipykernel install --user --name cadquery --display-name 'CadQuery (pixi)'",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-toolsai.jupyter",
                "bernhard-42.ocp-cad-viewer",
                "renan-r-santos.pixi-code"
            ],
            "settings": {
                "pixi-code.pixiExecutable": "/usr/local/bin/pixi",
                "python.defaultInterpreterPath": "${containerWorkspaceFolder}/.pixi/envs/default/bin/python"
            }
        }
    },
    "forwardPorts": [3939],
    "portsAttributes": {
        "3939": {
            "label": "OCP CAD Viewer",
            "onAutoForward": "silent"
        }
    }
}